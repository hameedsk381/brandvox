# Database
DATABASE_URL=postgresql+asyncpg://repuser:reppass@postgres:5432/reputationos
DATABASE_URL_SYNC=postgresql://repuser:reppass@postgres:5432/reputationos
POSTGRES_USER=repuser
POSTGRES_PASSWORD=reppass
POSTGRES_DB=reputationos

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Set to "production" to enforce startup security checks (real JWT_SECRET, ENCRYPTION_KEY)
ENVIRONMENT=development

# Fernet key for encrypting Google OAuth tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# When true, Google API failures fall back to generated mock data. Never enable in production.
DEMO_MODE=false

# Set false on replicas that should not run background jobs (an advisory lock
# also prevents duplicate scheduler runs across processes).
ENABLE_SCHEDULER=true

# Security (Phase 4)
AUDIT_LOG_RETENTION_DAYS=90
PASSWORD_RESET_EXPIRY_MINUTES=60
RATE_LIMIT_PER_WINDOW=5
RATE_LIMIT_WINDOW_SECONDS=300

# AI
GROQ_API_KEY=your-groq-api-key-here

# App
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Billing (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret (Razorpay Dashboard -> Webhooks). Falls back to
# RAZORPAY_KEY_SECRET if empty; webhooks are rejected without a valid signature.
RAZORPAY_WEBHOOK_SECRET=
